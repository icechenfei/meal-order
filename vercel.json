{
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "routes": [
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/", "dest": "/index.html" },
    { "handle": "filesystem" }
  ],
  "404": {
    "html": "/index.html"
  }
}
